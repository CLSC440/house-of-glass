rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserRole() {
      return currentUserExists()
        ? currentUserDoc().data.role
        : null;
    }

    function currentRoleDocExists() {
      return currentUserExists()
        && currentUserRole() != null
        && exists(/databases/$(database)/documents/roles/$(currentUserRole()));
    }

    function currentRoleDoc() {
      return get(/databases/$(database)/documents/roles/$(currentUserRole()));
    }

    function currentRolePermissions() {
      return currentRoleDocExists()
        ? currentRoleDoc().data.permissions
        : null;
    }

    function hasCustomRolePermission(permissionKey) {
      return currentRolePermissions() != null
        && currentRolePermissions()[permissionKey] == true;
    }

    function isAdmin() {
      return currentUserRole() == 'admin';
    }

    function isModerator() {
      return currentUserRole() == 'moderator';
    }

    function isAdminLike() {
      return isAdmin() || isModerator();
    }

    function hasAdminWorkspaceAccess() {
      return isAdminLike() || hasCustomRolePermission('accessAdmin');
    }

    function canManageProducts() {
      return isAdminLike() || hasCustomRolePermission('viewProducts');
    }

    function canManageStock() {
      return isAdminLike() || hasCustomRolePermission('viewStock');
    }

    function canManageOrders() {
      return isAdminLike() || hasCustomRolePermission('viewOrders');
    }

    function canViewUsers() {
      return isAdminLike()
        || hasCustomRolePermission('viewUsers')
        || hasCustomRolePermission('manageUsers');
    }

    function canManageUsers() {
      return isAdmin() || hasCustomRolePermission('manageUsers');
    }

    function canViewRoles() {
      return isAdmin()
        || hasCustomRolePermission('viewRoles')
        || hasCustomRolePermission('manageRoles')
        || hasCustomRolePermission('manageUsers');
    }

    function canManageRoles() {
      return isAdmin() || hasCustomRolePermission('manageRoles');
    }

    function canReadOwnRoleDefinition(roleId) {
      return currentUserExists() && currentUserRole() == roleId;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function signedInEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : null;
    }

    function orderBelongsToSignedInUser() {
      return isSignedIn() && (
        (resource.data.customer != null && resource.data.customer.uid == request.auth.uid)
        || (
          signedInEmail() != null
          && (
            (resource.data.customer != null && resource.data.customer.email == signedInEmail())
            || (resource.data.customerInfo != null && resource.data.customerInfo.email == signedInEmail())
          )
        )
      );
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if canManageProducts();
    }

    match /productCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if canManageProducts();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if canManageProducts();
    }

    match /categoryGroups/{groupId} {
      allow read: if true;
      allow create, update, delete: if canManageProducts();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || canViewUsers();
      allow create: if isOwner(userId) || canManageUsers();
      allow update: if canManageUsers()
        || (
          isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.uid == resource.data.uid
        );
      allow delete: if canManageUsers();
    }

    match /roles/{roleId} {
      allow read: if canReadOwnRoleDefinition(roleId) || canViewRoles() || canManageUsers();
      allow create, update, delete: if canManageRoles();
    }

    match /user_directory/{directoryId} {
      allow read, write: if canManageUsers();
    }

    match /notifications/{notificationId} {
      allow read: if isAdminLike()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, delete: if isAdminLike();
      allow update: if isAdminLike()
        || (
          isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read'])
        );
    }

    match /login_lookup/{lookupId} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if canManageUsers();
    }

    match /orders/{orderId} {
      allow read: if canManageOrders() || orderBelongsToSignedInUser();
      allow create: if isSignedIn()
        && request.resource.data.customer != null
        && request.resource.data.customer.uid == request.auth.uid;
      allow update, delete: if canManageOrders();
    }

    match /settings/{settingId} {
      allow read: if settingId == 'contact'
        || (settingId == 'orderCounter' && isSignedIn())
        || isAdminLike();
      allow write: if (settingId == 'orderCounter' && isSignedIn())
        || isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}